#!/usr/bin/env python3

"""Script to collect component metadata and save it for Report Portal integration."""

import argparse
import json
import logging
import os
import sys
from pathlib import Path

from dynaconf import settings

# Add testsuite to path
sys.path.insert(0, str(Path(__file__).parent.parent))

from testsuite.component_metadata import ComponentMetadataCollector
from testsuite.kubernetes.client import KubernetesClient


def main():
    parser = argparse.ArgumentParser(description="Collect component metadata for Report Portal")
    parser.add_argument(
        "--output", 
        "-o", 
        default="component-metadata.json",
        help="Output file for component metadata (default: component-metadata.json)"
    )
    parser.add_argument(
        "--kubeconfig",
        default=os.environ.get("KUBECONFIG"),
        help="Path to kubeconfig file (default: KUBECONFIG env var or current context)"
    )
    parser.add_argument(
        "--context",
        help="Kubernetes context to use (default: current context)"
    )
    parser.add_argument(
        "--verbose", 
        "-v", 
        action="store_true",
        help="Enable verbose logging"
    )
    
    args = parser.parse_args()
    
    # Setup logging
    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    )
    
    logger = logging.getLogger(__name__)
    
    try:
        # Create Kubernetes client
        cluster = KubernetesClient(
            project=settings["service_protection"]["system_project"],  # Default project
            kubeconfig_path=args.kubeconfig
        )
        
        # If a specific context was requested, we need to handle it differently
        if args.context:
            logger.warning(f"Context switching not directly supported. Using current context. Requested: {args.context}")
            # Note: You would need to switch context manually with kubectl before running this script
        
        # Collect component metadata
        collector = ComponentMetadataCollector(cluster)
        
        # Log component versions
        collector.log_component_versions()
        
        # Get metadata for Report Portal
        metadata = collector.get_component_metadata_for_report_portal()
        
        if not metadata:
            logger.warning("No component metadata collected")
            return 1
        
        # Save to file
        output_path = Path(args.output)
        with open(output_path, 'w') as f:
            json.dump(metadata, f, indent=2)
        
        logger.info(f"Component metadata saved to {output_path}")
        logger.info(f"Collected metadata for {len(metadata)} attributes")
        
        # Print summary
        print("\n=== Component Metadata Summary ===")
        for key, value in metadata.items():
            print(f"{key}: {value}")
        print("=" * 35)
        
        return 0
        
    except Exception as e:
        logger.error(f"Failed to collect component metadata: {e}")
        if args.verbose:
            import traceback
            traceback.print_exc()
        return 1


if __name__ == "__main__":
    sys.exit(main())
